{% render 'partials/head.liquid', title: nominee.title %}

<header class="site-header">

  <nav class="snelle-links-nav">
    <ul class="snelle-links-lijst pagina-container">
      <li><a href="/#faq">FAQ's</a></li>
      <li><a href="/#over-ons">Over ons</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
  </nav>

  <div class="hoofd-navigatie-balk">
    <nav class="hoofd-navigatie pagina-container">
      <a href="/" class="logo-link">
        <img src="/style/assets/logoad.png" alt="Overlegplatform Ad's" width="180" height="45">
      </a>

      <button class="hamburger" id="hamburger">
        ☰
      </button>

      <ul class="hoofd-menu" id="hoofd-menu">
        <li><a class="menu-link" href="/">Home</a></li>
        <li><a class="menu-link" href="/#uitleg">Over Ad's</a></li>
        <li><a class="menu-link" href="/#publicaties">Publicaties</a></li>
        <li><a class="menu-link actief" href="/genomineerden">Talent Award</a></li>
        <li><a class="menu-link" href="/#nieuws">Nieuws</a></li>
        <li class="menu-cta">
          <a href="/#ad-dag" class="knop-cta">Kom naar Ad-dag</a>
        </li>
      </ul>

      <a href="/#ad-dag" class="knop-cta desktop-cta">Kom naar Ad-dag</a>
    </nav>
  </div>

</header>

<main class="pagina-container" id="inhoud">

  <div class="pagina-intro">
    <p>
      <a class="tekst-link" href="/genomineerden">← Terug naar overzicht</a>
    </p>
  </div>

  <div class="genomineerde-detail">
    <article class="genomineerde-detail-kaart">
      <figure class="detail-afbeelding">
        {% if nominee.profile_picture %}
          <img src="https://fdnd-agency.directus.app/assets/{{ nominee.profile_picture }}" alt="{{ nominee.title }}" width="500" height="500">
        {% else %}
          <img src="/style/assets/fotothijs.jpg" alt="{{ nominee.title }}" width="500" height="500">
        {% endif %}
      </figure>

      <div class="detail-inhoud">
        <h1>{{ nominee.title }}</h1>

        {% if nominee.institution %}
          <p><strong>Onderwijsinstelling:</strong> {{ nominee.institution }}</p>
        {% endif %}

        {% if nominee.course %}
          <p><strong>Opleiding:</strong> {{ nominee.course }}</p>
        {% endif %}

        {% if nominee.education_variant %}
          <p><strong>Variant:</strong> {{ nominee.education_variant }}</p>
        {% endif %}

        {% if nominee.previous_course %}
          <p><strong>Vorige opleiding:</strong> {{ nominee.previous_course }}</p>
        {% endif %}

        {% if nominee.header %}
          <p><strong>Categorie:</strong> {{ nominee.header }}</p>
        {% endif %}

        {% if nominee.date %}
          <p><strong>Datum:</strong> {{ nominee.date }}</p>
        {% endif %}

        {% if nominee.excerpt %}
          <section>
            <h2>Korte introductie</h2>
            {{ nominee.excerpt }}
          </section>
        {% endif %}

        {% if nominee.body %}
          <section>
            <h2>Meer over deze genomineerde</h2>
            {{ nominee.body }}
          </section>
        {% endif %}
      </div>
    </article>
  </div>

  <footer class="site-footer" id="contact">
    <section class="footer-blok">
      <h2>Overlegplatform Ad's</h2>
      <p>
        Het Overlegplatform Associate degrees brengt Ad-opleidingen samen
        om kennis te delen en profielen af te stemmen.
      </p>
    </section>

    <section class="footer-blok">
      <h2>Contact</h2>
      <p>
        <a class="footer-link" href="mailto:platformassociatedegrees@outlook.com">
          platformassociatedegrees@outlook.com
        </a>
      </p>
      <p class="footer-klein">
        © Overlegplatform Associate degrees. Alle rechten voorbehouden
      </p>
    </section>
  </footer>

</main>

{% render 'partials/foot.liquid' %}